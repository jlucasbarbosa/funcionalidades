NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# FLW/CECI endpoint used by transferSession(sessionId).
# The service sends PUT with type=DEPARTMENT and newDepartmentId.
WTS_TRANSFER_SESSION_URL=https://api.wts.chat/chat/v1/session/{id}/transfer
WTS_API_TOKEN=your-api-token
WTS_TIMEOUT_MS=10000

SESSION_TIMEOUT_MINUTES=15
WORKER_CRON=*/60 * * * * *
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
